# Copy this to .env.local and fill in your values

# Mapbox public access token (from https://account.mapbox.com)
# VITE_-prefixed: inlined into the client bundle at build time. This is a
# public token — restrict it to your deployment URL in the Mapbox dashboard.
VITE_MAPBOX_TOKEN=pk.eyJ1...

# ADS-B Exchange supporter-tier API key (RapidAPI). Deliberately NOT
# VITE_-prefixed so it never enters the client bundle. In dev the Vite proxy
# attaches it server-side (vite.config.ts); in production it lives in Azure
# Static Web App application settings (see DEPLOYMENT.md).
ADSBX_API_KEY=your_key_here
